# Copia a .env.dev o .env.large según el perfil que quieras usar
# Luego ejecuta: make dev  o  make large

HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxx

# ── Perfil DEV ───────────────────────────────────────────────────────────────
# MODEL_ID=google/gemma-4-E4B-it
# MAX_MODEL_LEN=16384
# EXTRA_VLLM_ARGS=

# ── Perfil LARGE (MoE INT4 + CPU offload) ────────────────────────────────────
# MODEL_ID=google/gemma-4-26B-A4B-it
# MAX_MODEL_LEN=4096
# EXTRA_VLLM_ARGS=--quantization bitsandbytes --cpu-offload-gb 8

# ── Común ────────────────────────────────────────────────────────────────────
GPU_COUNT=1
VLLM_PORT=8000
VLLM_API_KEY=
