# Copia el bloque del backend que vayas a usar a .env (o usa `make dev`/`make vllm-dev`,
# que copian .env.ollama o .env.dev automáticamente).

# ── Perfil OLLAMA (recomendado en laptop, 8GB VRAM) ──────────────────────────
OLLAMA_PORT=11434
OLLAMA_MODEL=gemma4:e4b
OLLAMA_KEEP_ALIVE=5m
OLLAMA_NUM_PARALLEL=1

# ── Perfil vLLM (avanzado, GPUs ≥16GB) ───────────────────────────────────────
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxx

# Perfil DEV
# MODEL_ID=google/gemma-4-E4B-it
# MAX_MODEL_LEN=16384
# EXTRA_VLLM_ARGS=

# Perfil LARGE (MoE INT4 + CPU offload)
# MODEL_ID=google/gemma-4-26B-A4B-it
# MAX_MODEL_LEN=4096
# EXTRA_VLLM_ARGS=--quantization bitsandbytes --cpu-offload-gb 8

# Común vLLM
GPU_COUNT=1
VLLM_PORT=8000
VLLM_API_KEY=
